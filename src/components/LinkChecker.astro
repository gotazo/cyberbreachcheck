<script type="module">
  const badKeywords = ['login', 'verify', 'secure', 'account', 'update', 'wp-admin', 'bank', 'confirm', 'password'];

  const linkInput = document.getElementById('link-input');
  const checkBtn = document.getElementById('link-check-btn');
  const errorText = document.getElementById('link-error');
  const loading = document.getElementById('link-loading');
  const resultBox = document.getElementById('link-result');
  const actionBox = document.getElementById('link-action');

  const isValidUrl = (value) => {
    try {
      const url = new URL(value.startsWith('http') ? value : `https://${value}`);
      return url.protocol === 'http:' || url.protocol === 'https:';
    } catch {
      return false;
    }
  };

  const getFeedback = (url) => {
    const normalized = url.trim().toLowerCase();
    const hasHttp = normalized.startsWith('http://');
    const hasHttps = normalized.startsWith('https://');
    const length = normalized.length;

    const keywords = badKeywords.filter((k) => normalized.includes(k));
    const hasKeyword = keywords.length > 0;
    const hasNumbers = /\d/.test(normalized);
    const hasRandom = /[a-z]{10,}/.test(normalized);

    if (hasHttp || hasKeyword || length > 120) {
      return {
        label: 'Dangerous',
        color: 'border-red-500 bg-red-950/40 text-red-300',
        summary: 'High-risk indicators detected.',
        details: `Avoid this link. ${hasKeyword ? `Keywords found: ${keywords.join(', ')}` : ''}`,
      };
    }

    if (!hasHttps || length > 90 || hasNumbers || hasRandom) {
      return {
        label: 'Suspicious',
        color: 'border-yellow-500 bg-yellow-950/30 text-yellow-300',
        summary: 'Unusual structure or pattern.',
        details: 'Check carefully before clicking.',
      };
    }

    return {
      label: 'Safe',
      color: 'border-emerald-500 bg-emerald-950/30 text-emerald-300',
      summary: 'Looks safe, but always verify.',
      details: 'No major red flags detected.',
    };
  };

  checkBtn.addEventListener('click', async () => {
    const value = linkInput.value.trim();

    if (!value) {
      errorText.textContent = 'Please enter a URL.';
      errorText.classList.remove('hidden');
      return;
    }

    if (!isValidUrl(value)) {
      errorText.textContent = 'Invalid URL format.';
      errorText.classList.remove('hidden');
      return;
    }

    errorText.classList.add('hidden');
    loading.classList.remove('hidden');
    resultBox.classList.add('hidden');
    actionBox.classList.add('hidden');

    checkBtn.disabled = true;
    checkBtn.textContent = 'Analyzing...';

    await new Promise((r) => setTimeout(r, 1500));

    const feedback = getFeedback(value);

    resultBox.className = `mt-4 rounded-xl border p-4 ${feedback.color}`;
    resultBox.innerHTML = `
      <h3 class="font-bold text-lg">${feedback.label}</h3>
      <p class="mt-2 text-sm">${feedback.summary}</p>
      <p class="mt-1 text-xs text-gray-200">${feedback.details}</p>
    `;

    loading.classList.add('hidden');
    resultBox.classList.remove('hidden');
    actionBox.classList.remove('hidden');

    checkBtn.disabled = false;
    checkBtn.textContent = 'Check Link';
  });
</script>
<section class="max-w-3xl mx-auto bg-gray-900/70 border border-gray-800 rounded-2xl p-6 sm:p-8">
  
  <div class="mb-5">
    <h2 class="text-2xl font-bold text-white">Suspicious Link Checker</h2>
    <p class="text-sm text-gray-400 mt-1">Enter a URL and get a quick verdict.</p>
  </div>

  <div class="grid gap-3 sm:grid-cols-[1fr_auto]">
    <input id="link-input" type="text" placeholder="https://example.com"
      class="w-full rounded-xl border border-gray-700 bg-gray-950 px-4 py-3 text-white" />
    
    <button id="link-check-btn"
      class="rounded-xl bg-cyan-500 py-3 px-5 font-semibold text-black">
      Check Link
    </button>
  </div>

  <p id="link-error" class="mt-3 text-sm text-red-400 hidden"></p>

  <div id="link-loading" class="mt-4 text-gray-300 hidden">
    Analyzing link...
  </div>

  <div id="link-result" class="mt-4 hidden rounded-xl border p-4"></div>

  <div id="link-action" class="mt-4 hidden text-gray-300">
    Stay cautious with unknown links.
  </div>
  <div class="mt-4 p-4 border border-gray-800 rounded-xl bg-gray-900/60">
  <p class="text-sm text-gray-300 mb-3">
    ⚠️ Visiting risky links? Protect your data with a secure VPN.
  </p>

  <a 
    href="https://go.nordvpn.net/aff_c?offer_id=15&aff_id=140489&url_id=902" 
    target="_blank" 
    rel="noopener noreferrer"
    class="inline-block px-4 py-2 rounded-lg font-semibold text-sm"
    style="background-color:#00ff9f; color:#020617"
  >
    Get NordVPN →
  </a>
</div>

</section>

