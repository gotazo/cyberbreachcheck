---
const {title, description, href, tag = 'Guide'} = Astro.props;
---
<a href={href} class="block border border-gray-800 rounded-xl p-6 hover:border-gray-700 hover:bg-gray-900/30 transition group">
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-lg font-semibold text-white group-hover:text-white transition">{title}</h3>
    <span style="background-color: #00ff9f; color: #020617" class="text-xs px-3 py-1 rounded-md font-bold flex-shrink-0 ml-2">{tag}</span>
  </div>
  <p class="text-sm text-gray-400">{description}</p>
</a>
