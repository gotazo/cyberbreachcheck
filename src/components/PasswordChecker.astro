---
---

<section class="max-w-4xl mx-auto bg-gray-900/70 border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-lg shadow-cyan-900/20">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-white">Password Strength Checker</h2>
    <p class="text-sm text-gray-400 mt-1">Check your password strength and get recommendations for improvement.</p>
  </div>

  <div class="space-y-4 mb-6">
    <div>
      <label for="password-input" class="block text-sm font-medium text-gray-300 mb-2">Password</label>
      <input id="password-input" type="password" placeholder="Enter your password..." class="w-full rounded-xl border border-gray-700 bg-gray-950 px-4 py-3 text-white outline-none focus:border-emerald-400 transition" />
    </div>
  </div>

  <div class="flex justify-center">
    <button id="check-btn" class="rounded-xl bg-cyan-500 py-3 px-8 font-semibold text-slate-950 hover:bg-cyan-400 transition cursor-pointer">Check Password</button>
  </div>

  <p id="password-error" class="mt-4 text-sm text-red-400 text-center hidden"></p>

  <div id="password-loading" class="mt-6 inline-flex items-center gap-2 text-gray-300 justify-center w-full hidden">
    <div class="h-5 w-5 rounded-full border-2 border-gray-500 border-t-white animate-spin"></div>
    Checking password...
  </div>

  <div id="password-result" class="mt-6 hidden rounded-xl border p-6 transition-all duration-300"></div>
<div class="mt-4 text-sm text-gray-300">
  Weak password detected. Use a secure password manager.
  
  <br />

  <a 
    href="https://go.nordpass.io/aff_c?offer_id=488&aff_id=140489&url_id=9356"
    target="_blank"
    rel="noopener noreferrer"
    class="text-emerald-400 font-semibold"
  >
    Try NordPass →
  </a>
</div>
</section>

<script type="module">
  const passwordInput = document.getElementById('password-input');
  const checkBtn = document.getElementById('check-btn');
  const resultBox = document.getElementById('password-result');
  const errorText = document.getElementById('password-error');

  function analyzePassword(pwd) {
    const length = pwd.length;
    const hasUpper = /[A-Z]/.test(pwd);
    const hasLower = /[a-z]/.test(pwd);
    const hasNumber = /[0-9]/.test(pwd);
    const hasSymbol = /[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(pwd);

    const charTypes = [hasUpper, hasLower, hasNumber, hasSymbol].filter(Boolean).length;

    // Calculate strength score (0-100)
    let score = 0;
    score += Math.min(length * 5, 30);
    score += charTypes * 15;
    score += (hasUpper && hasLower ? 10 : 0);

    let strength, colorClass, crackTime;
    let suggestions = [];

    if (length < 6 || (hasLower && !hasUpper && !hasNumber && !hasSymbol)) {
      strength = 'WEAK';
      colorClass = 'border-red-500 bg-red-950/40 text-red-300';
      crackTime = 'seconds';
      score = Math.min(score, 35);
    } else if (length <= 10 && charTypes < 3) {
      strength = 'MEDIUM';
      colorClass = 'border-yellow-500 bg-yellow-950/30 text-yellow-300';
      crackTime = charTypes === 2 ? 'hours' : 'days';
      score = Math.max(Math.min(score, 70), 36);
    } else if (length >= 10 && charTypes >= 3) {
      strength = 'STRONG';
      colorClass = 'border-emerald-500 bg-emerald-950/30 text-emerald-300';
      crackTime = length >= 12 ? 'centuries' : 'years';
      score = Math.min(100, Math.max(score, 71));
    } else {
      strength = 'MEDIUM';
      colorClass = 'border-yellow-500 bg-yellow-950/30 text-yellow-300';
      crackTime = 'weeks';
      score = Math.max(Math.min(score, 70), 36);
    }

    if (length < 6) suggestions.push('Use at least 6 characters');
    if (!hasNumber) suggestions.push('Add numbers');
    if (!hasSymbol) suggestions.push('Add symbols');

    return { strength, colorClass, length, charTypes, suggestions, score, crackTime, hasUpper, hasLower, hasNumber, hasSymbol };
  }

  checkBtn.addEventListener('click', () => {
    const pwd = passwordInput.value;

    if (!pwd) {
      errorText.textContent = 'Please enter a password to check.';
      errorText.classList.remove('hidden');
      resultBox.classList.add('hidden');
      return;
    }

    errorText.classList.add('hidden');
    const analysis = analyzePassword(pwd);

    const barColor = analysis.strength === 'WEAK' ? 'bg-red-500' : analysis.strength === 'MEDIUM' ? 'bg-yellow-500' : 'bg-emerald-500';
    const checklist = [
      { label: 'Length (6+)', check: analysis.length >= 6 },
      { label: 'Uppercase', check: analysis.hasUpper },
      { label: 'Numbers', check: analysis.hasNumber },
      { label: 'Symbols', check: analysis.hasSymbol }
    ];

    resultBox.className = `mt-6 rounded-xl border p-6 ${analysis.colorClass} transition-all duration-300`;
    resultBox.innerHTML = `
      <div class="space-y-4">
        <div class="flex items-center justify-between">
          <h3 class="font-bold text-lg">Strength: ${analysis.strength}</h3>
          <span class="text-xs font-semibold opacity-75">Length: ${analysis.length}</span>
        </div>

        <div class="space-y-2">
          <div class="flex justify-between text-xs opacity-75">
            <span>Strength</span>
            <span>${analysis.score}%</span>
          </div>
          <div class="w-full bg-gray-700 rounded-full h-2">
            <div class="${barColor} h-2 rounded-full transition-all duration-300" style="width: ${analysis.score}%"></div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-2">
          ${checklist.map(item => `
            <div class="flex items-center gap-2 text-xs">
              <span class="${item.check ? 'text-emerald-400' : 'text-gray-500'}">
                ${item.check ? '✓' : '○'}
              </span>
              <span>${item.label}</span>
            </div>
          `).join('')}
        </div>

        <div class="pt-2 border-t border-current border-opacity-20">
          <p class="text-xs opacity-75">Estimated crack time: <span class="font-semibold">${analysis.crackTime}</span></p>
        </div>

        ${analysis.suggestions.length > 0 ? `
          <div class="text-sm">
            <p class="font-semibold text-xs opacity-80 mb-1">Suggestions:</p>
            <ul class="space-y-1">${analysis.suggestions.map(s => `<li class="text-xs">• ${s}</li>`).join('')}</ul>
          </div>
        ` : '<p class="text-sm font-semibold opacity-90">✓ Password looks strong!</p>'}
      </div>
    `;

    resultBox.classList.remove('hidden');
  });

  passwordInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') checkBtn.click();
  });
</script>
