---
import '../styles/global.css';

import Navbar from './Navbar.astro';
import Footer from './Footer.astro';

const {children, title = 'CyberBreachCheck', description = 'Check if you are exposed and get actionable cybersecurity advice.'} = Astro.props;
const siteTitle = `${title} | CyberBreachCheck`;
---
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#020617" />
    <title>{siteTitle}</title>
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body style="background-color: #020617" class="text-gray-100 min-h-screen font-sans antialiased">
    <div class="min-h-screen flex flex-col">
      <Navbar />
      <main class="flex-1 w-full mx-auto">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

