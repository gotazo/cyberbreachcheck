<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="rounded-2xl border border-gray-800 p-8 sm:p-12" style="background: linear-gradient(135deg, rgba(0, 255, 159, 0.05) 0%, rgba(34, 197, 94, 0.02) 100%)">
    <div class="text-center max-w-2xl mx-auto mb-8">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Complete Your Security Toolkit</h2>
      <p class="text-lg text-gray-300">Complement your breach check with trusted privacy and security tools.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="#" class="group border border-gray-800 rounded-xl p-6 hover:border-gray-700 hover:bg-gray-900/30 transition text-center">
        <div class="w-12 h-12 rounded-lg mx-auto mb-4 flex items-center justify-center" style="background-color: rgba(0, 255, 159, 0.1), border: 1px solid rgba(0, 255, 159, 0.3)">
          <svg class="w-6 h-6" style="color: #00ff9f" fill="currentColor" viewBox="0 0 20 20">
            <path d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633z" />
            <path fill-rule="evenodd" d="M19.854 5.146a1 1 0 010 1.414l-10 10a1 1 0 11-1.414-1.414l10-10a1 1 0 011.414 0zM7.146 19.854a1 1 0 010-1.414l10-10a1 1 0 011.414 1.414l-10 10a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="font-semibold text-white mb-2">Password Manager</h3>
        <p class="text-sm text-gray-400 mb-4">Store credentials securely and generate strong passwords.</p>
        <span style="color: #00ff9f" class="text-sm font-semibold inline-block group-hover:underline">Explore →</span>
      </a>

      <a href="#" class="group border border-gray-800 rounded-xl p-6 hover:border-gray-700 hover:bg-gray-900/30 transition text-center">
        <div class="w-12 h-12 rounded-lg mx-auto mb-4 flex items-center justify-center" style="background-color: rgba(0, 255, 159, 0.1), border: 1px solid rgba(0, 255, 159, 0.3)">
          <svg class="w-6 h-6" style="color: #00ff9f" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M15.12 5.636a3 3 0 012.088.712A3 3 0 0119 8v6a3 3 0 01-1.792 2.652A3 3 0 0115.12 14.364M9.25 7a.75.75 0 000 1.5A2.25 2.25 0 0111.5 10.75.75.75 0 0013 10.75a3.75 3.75 0 00-3.75-3.75z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="font-semibold text-white mb-2">VPN Service</h3>
        <p class="text-sm text-gray-400 mb-4">Encrypt your connection on public networks and browse privately.</p>
        <span style="color: #00ff9f" class="text-sm font-semibold inline-block group-hover:underline">Explore →</span>
      </a>

      <a href="#" class="group border border-gray-800 rounded-xl p-6 hover:border-gray-700 hover:bg-gray-900/30 transition text-center">
        <div class="w-12 h-12 rounded-lg mx-auto mb-4 flex items-center justify-center" style="background-color: rgba(0, 255, 159, 0.1), border: 1px solid rgba(0, 255, 159, 0.3)">
          <svg class="w-6 h-6" style="color: #00ff9f" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.5.75v8.5c0 .414.336.75.75.75h8.5c.414 0 .75-.336.75-.75v-4a.75.75 0 00-1.5 0v3.25H4.75V6.25h3.25a.75.75 0 000-1.5h-4z" clip-rule="evenodd" />
            <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 001.06.053L16.5 2.5h-3.25a.75.75 0 000-1.5h5a.75.75 0 00.75.75v5a.75.75 0 00-1.5 0V4.5L6.247 13.813a.75.75 0 00-.053-1.06z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="font-semibold text-white mb-2">Antivirus</h3>
        <p class="text-sm text-gray-400 mb-4">Real-time protection against malware and threats.</p>
        <span style="color: #00ff9f" class="text-sm font-semibold inline-block group-hover:underline">Explore →</span>
      </a>
    </div>
  </div>
</section>
