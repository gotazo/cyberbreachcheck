---
import Layout from '../components/Layout.astro';
---

<Layout title="Contact">
  <section class="max-w-2xl mx-auto px-4 py-16 text-center text-gray-300">
    <h1 class="text-3xl font-bold text-white mb-6">Contact Us</h1>

    <p class="mb-4">
      For inquiries, support, or business collaborations:
    </p>

    <a 
      href="mailto:hello@cyberbreachcheck.com" 
      class="text-emerald-400 font-semibold text-lg"
    >
      Say Hello via Email
    </a>
  </section>
</Layout>