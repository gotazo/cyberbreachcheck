---
import Layout from '../../components/Layout.astro';
import GuideCard from '../../components/GuideCard.astro';
---
<Layout title="Guides" description="Actionable cybersecurity guides for password protection, VPNs, and antivirus defenses.">
  <section class="max-w-4xl mx-auto mb-8">
    <h1 class="text-3xl font-bold text-white">Guides</h1>
    <p class="text-slate-300 mt-2">Trusted resources to help you become more secure online.</p>
  </section>

  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <GuideCard
      title="How to secure passwords"
      description="Strong passwords and password managers are your first line of defense."
      href="/guides/password-security"
    />
    <GuideCard
      title="Choosing a VPN"
      description="Get privacy while browsing and working remotely with the right VPN."
      href="/guides/vpn-selection"
    />
    <GuideCard
      title="Antivirus vs endpoint protection"
      description="Understand what protection you need and which tool category to choose."
      href="/guides/antivirus-basics"
    />
  </section>
</Layout>
