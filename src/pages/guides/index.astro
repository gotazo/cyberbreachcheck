---
import Layout from '../../components/Layout.astro';
import GuideCard from '../../components/GuideCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---
<Layout title="Guides" description="Actionable cybersecurity guides for password protection, VPNs, and antivirus defenses.">
  <section class="max-w-4xl mx-auto mb-8">
    <h1 class="text-3xl font-bold text-white">Guides</h1>
    <p class="text-slate-300 mt-2">Trusted resources to help you become more secure online.</p>
  </section>

  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => (
      <GuideCard
        title={post.data.title}
        description={post.data.description}
        href={`/guides/${post.id}`}
      />
    ))}
  </section>
</Layout>
