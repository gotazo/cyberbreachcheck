---
import Layout from '../../components/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<Layout 
  title="Guides" 
  description="Actionable cybersecurity guides to protect your accounts, data, and identity."
>

  <!-- HERO -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-12 text-center">
    
    <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight">
      Security Guides
    </h1>

    <p class="mt-6 text-lg text-gray-400 max-w-2xl mx-auto">
      Learn how to protect yourself from phishing attacks, unsafe links, and online threats.
    </p>

  </section>

  <!-- GRID -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

      {posts.map((post) => (
        <a 
          href={`/guides/${post.id}`} 
          class="group block p-6 rounded-2xl border border-gray-800 bg-gray-900/70 
                 hover:border-gray-700 hover:bg-gray-900 transition duration-200"
        >

          <!-- TITLE -->
          <h2 class="text-lg font-semibold text-white group-hover:text-emerald-400 transition">
            {post.data.title}
          </h2>

          <!-- DESCRIPTION -->
          <p class="mt-3 text-sm text-gray-400 leading-relaxed">
            {post.data.description}
          </p>

          <!-- FOOTER -->
          <div class="mt-6 flex items-center justify-between text-sm text-gray-500">
            <span>Read guide</span>
            <span class="group-hover:translate-x-1 transition">→</span>
          </div>

        </a>
      ))}

    </div>

  </section>

</Layout>