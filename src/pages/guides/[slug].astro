---
import ReadingLayout from '../../layouts/ReadingLayout.astro';
import { getCollection, render } from 'astro:content';

import LinkChecker from '../../components/LinkChecker.astro';
import EmailAnalyzer from '../../components/EmailAnalyzer.astro';
import PasswordChecker from '../../components/PasswordChecker.astro';

// ✅ Required for dynamic routes
export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

// Get all posts
const posts = await getCollection('blog');

// Current post
const post = posts.find((entry) => entry.id === Astro.params.slug);

if (!post) {
  throw new Error(`Guide not found for slug: ${Astro.params.slug}`);
}

// Render MDX
const { Content } = await render(post);

// ✅ Reading time (simple estimate)
const words = post.body.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 200));

// ✅ Related posts
const relatedPosts = posts
  .filter((p) => p.id !== post.id)
  .slice(0, 5);
---

<ReadingLayout title={post.data.title} description={post.data.description}>

  <!-- TITLE -->
  <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">
    {post.data.title}
  </h1>

  <!-- META -->
  <div class="flex items-center gap-4 text-sm text-gray-400 mb-8">
    <span>📅 {post.data.pubDate}</span>
    <span>⏱ {readingTime} min read</span>
  </div>

  <!-- DESCRIPTION -->
  <p class="text-gray-400 mb-10">
    {post.data.description}
  </p>

  <!-- ARTICLE -->
  <Content components={{ LinkChecker, EmailAnalyzer, PasswordChecker }} />

  <!-- TOOL CTA -->
  <div class="mt-12 p-6 border border-gray-800 rounded-xl bg-gray-900/60">
    <p class="text-gray-300 mb-4">
      Not sure about a link? Analyze it instantly with our tool.
    </p>

    <a href="/check/link" class="text-emerald-400 font-semibold hover:text-emerald-300">
      Use Link Checker →
    </a>
  </div>

  <!-- SIDEBAR -->
  <div slot="sidebar" class="space-y-6">

    <!-- TOOLS -->
    <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/70">
      <h3 class="text-sm font-semibold text-gray-400 mb-3">TOOLS</h3>

      <div class="space-y-3">
        <a href="/check/link" class="block text-emerald-400 hover:underline">
          → Check Suspicious Link
        </a>

        <a href="/check/email-scam" class="block text-emerald-400 hover:underline">
          → Analyze Email Scam
        </a>

        <a href="/check/password" class="block text-emerald-400 hover:underline">
          → Test Password Strength
        </a>
      </div>
    </div>

    <!-- RELATED POSTS -->
    <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/70">
      <h3 class="text-sm font-semibold text-gray-400 mb-3">RELATED GUIDES</h3>

      <div class="space-y-3">
        {relatedPosts.map((item) => (
          <a 
            href={`/guides/${item.id}`} 
            class="block text-gray-300 hover:text-white"
          >
            {item.data.title}
          </a>
        ))}
      </div>
    </div>

    <!-- AFFILIATE CTA -->
    <div class="p-5 rounded-xl border border-gray-800 bg-gray-900/70">
      <p class="text-sm text-gray-300 mb-3">
        Stay protected from phishing attacks and unsafe websites.
      </p>

      <a 
        href="https://go.nordvpn.net/aff_c?offer_id=15&aff_id=140489&url_id=902"
        target="_blank"
        class="inline-block px-4 py-2 rounded-lg text-sm font-semibold"
        style="background-color:#00ff9f; color:#020617"
      >
        Get NordVPN →
      </a>

      <p class="text-xs text-gray-500 mt-3">
        Affiliate link: we may earn a commission at no extra cost to you.
      </p>
    </div>

  </div>

</ReadingLayout>