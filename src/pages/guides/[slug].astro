---
import Layout from '../../components/Layout.astro';

const guideMap = {
  'password-security': {
    title: 'How to secure passwords',
    description: 'Create unique credentials, use a password manager, and run routine audits.',
    points: [
      'Use a high-quality password manager (affiliate friendly).',
      'Generate unique passwords per service with 16+ characters.',
      'Enable 2FA and remove unused account access.'
    ]
  },
  'vpn-selection': {
    title: 'Choosing a VPN',
    description: 'Compare speed, privacy policy, and server locations before subscribing.',
    points: [
      'Select no-log providers that support OpenVPN/WireGuard.',
      'Test for DNS/IP leak protection and fast connections.',
      'Use a reputable VPN for public Wi-Fi safety.'
    ]
  },
  'antivirus-basics': {
    title: 'Antivirus vs endpoint protection',
    description: 'Layer your defense with both local scanning and browser security.',
    points: [
      'Combine endpoint security with real-time anti-malware scans.',
      'Keep definitions updated and avoid unknown software.',
      'Run quarterly full-system scans and deep vulnerability checks.'
    ]
  }
};

export async function getStaticPaths() {
  return [
    { params: { slug: 'password-security' } },
    { params: { slug: 'vpn-selection' } },
    { params: { slug: 'antivirus-basics' } }
  ];
}

const slug = String(Astro.params.slug);
const guide = (guideMap as Record<string, {title:string; description:string; points:string[]}>)[slug];
---

{guide ? (
  <Layout title={guide.title} description={guide.description}>
    <section class="max-w-3xl mx-auto">
      <h1 class="text-3xl font-bold text-white mb-3">{guide.title}</h1>
      <p class="text-slate-300 mb-6">{guide.description}</p>
      <div class="space-y-3">
        {guide.points.map((item: string) => (
          <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
            <p class="text-slate-100">{item}</p>
          </div>
        ))}
      </div>
    </section>
  </Layout>
) : (
  <Layout title="Guide not found" description="Guide not found">
    <section class="max-w-2xl mx-auto text-center">
      <h1 class="text-3xl font-bold text-white">Guide not found</h1>
      <p class="text-slate-400 mt-2">The guide you requested does not exist. <a href="/guides" class="text-cyan-300">Go back to guides</a>.</p>
    </section>
  </Layout>
)}
