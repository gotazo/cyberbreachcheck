---
import Layout from '../../components/Layout.astro';
import { getCollection, render } from 'astro:content';

import LinkChecker from '../../components/LinkChecker.astro';
import EmailAnalyzer from '../../components/EmailAnalyzer.astro';
import PasswordChecker from '../../components/PasswordChecker.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  console.log(posts);

  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const posts = await getCollection('blog');
const post = posts.find((entry) => entry.id === Astro.params.slug);

if (!post) {
  throw new Error(`Guide not found for slug: ${Astro.params.slug}`);
}

const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
      {post.data.title}
    </h1>

    <p class="text-gray-400 mb-8">
      {post.data.description}
    </p>

    <article class="prose prose-invert max-w-none">
      <Content components={{ LinkChecker, EmailAnalyzer, PasswordChecker }} />
    </article>

    <div class="mt-10 p-6 border border-gray-800 rounded-xl bg-gray-900/60">
      <p class="text-gray-300 mb-4">
        Not sure about a link? Analyze it instantly with our tool.
      </p>

      <a
        href="/check/link"
        class="text-emerald-400 font-semibold hover:text-emerald-300"
      >
        Use Link Checker ->
      </a>
    </div>

    <div class="mt-6 p-6 border border-gray-800 rounded-xl bg-gray-900/60">
      <p class="text-gray-300 mb-4">
        Stay protected from phishing attacks and unsafe websites.
      </p>

      <a
        href="https://go.nordvpn.net/aff_c?offer_id=15&aff_id=140489&url_id=902"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-4 py-2 rounded-lg font-semibold text-sm"
        style="background-color:#00ff9f; color:#020617"
      >
        Get NordVPN ->
      </a>

      <p class="text-xs text-gray-500 mt-3">
        Affiliate link: we may earn a commission at no extra cost to you.
      </p>
    </div>
  </section>
</Layout>
