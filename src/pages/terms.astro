---
import Layout from '../components/Layout.astro';
---

<Layout title="Terms and Conditions">
  <section class="max-w-3xl mx-auto px-4 py-16 text-gray-300">
    <h1 class="text-3xl font-bold text-white mb-6">Terms & Conditions</h1>

    <p class="mb-4">
      The tools provided on this website are for informational purposes only.
    </p>

    <p class="mb-4">
      We do not guarantee accuracy of results. Users should verify independently.
    </p>

    <p class="mb-4">
      We are not responsible for any damages resulting from use of this site.
    </p>

    <p>
      By using this site, you agree to these terms.
    </p>
  </section>
</Layout>