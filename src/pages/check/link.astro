---
import Layout from '../../components/Layout.astro';
import LinkChecker from '../../components/LinkChecker.astro';
---
<Layout title="Link Checker" description="Suspicious link checker for immediate URL safety insight.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-3xl font-bold text-white mb-4">Suspicious Link Checker</h1>
    <p class="text-gray-400 mb-8">Paste any URL and get a quick verdict on whether it's safe, suspicious, or dangerous.</p>
    <LinkChecker />
  </section>
</Layout>