---
import Layout from '../../components/Layout.astro';
import EmailInput from '../../components/EmailInput.astro';
---
<Layout title="Email Breach Check" description="Perform a quick email exposure check and learn how to act fast.">
  <section class="max-w-3xl mx-auto text-center mb-8">
    <h1 class="text-3xl font-bold text-white mb-3">Email breach check</h1>
    <p class="text-slate-300">Use the form below to simulate checking for leaked accounts and exposed credentials.</p>
  </section>

  <section class="max-w-3xl mx-auto mb-8">
    <EmailInput buttonText="Check Email" placeholder="hello@yourdomain.com" />
  </section>

  <section class="max-w-3xl mx-auto p-5 rounded-2xl border border-slate-800 bg-slate-900/70">
    <h2 class="text-lg font-semibold text-cyan-200 mb-2">Next steps</h2>
    <ul class="text-slate-300 list-disc list-inside space-y-2">
      <li>Change passwords for any accounts using this email.</li>
      <li>Enable two-factor authentication where available.</li>
      <li>Review any connected password managers and reset compromised entries.</li>
    </ul>
  </section>
</Layout>
