---
import Layout from '../../components/Layout.astro';
import EmailInput from '../../components/EmailInput.astro';
---

<Layout title="Email Breach Checker">
  <section class="max-w-3xl mx-auto px-4 py-20 text-center">

    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
      Check if your email was breached
    </h1>

    <p class="text-gray-400 mb-8">
      Instantly scan your email for exposure and get clear next steps.
    </p>

    <!-- Use your component -->
    <EmailInput buttonText="Scan Now" placeholder="Enter your email" />

    <!-- Fake result -->
    <div class="mt-10 p-6 rounded-lg border border-gray-800 bg-gray-900/50 max-w-md mx-auto">
      <p class="text-green-400 font-semibold">✔ No breaches found</p>
      <p class="text-gray-400 text-sm mt-2">
        Your email appears safe. Stay protected with strong passwords.
      </p>
    </div>

  </section>
</Layout>