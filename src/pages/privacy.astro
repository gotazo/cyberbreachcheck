---
import Layout from '../components/Layout.astro';
---

<Layout title="Privacy Policy">
  <section class="max-w-3xl mx-auto px-4 py-16 text-gray-300">
    <h1 class="text-3xl font-bold text-white mb-6">Privacy Policy</h1>

    <p class="mb-4">
      We respect your privacy. We do not store personal data entered into our tools.
    </p>

    <p class="mb-4">
      This website may use cookies and third-party services for analytics and affiliate tracking.
    </p>

    <p class="mb-4">
      We may earn commissions from affiliate links at no extra cost to you.
    </p>

    <p>
      By using this website, you agree to this policy.
    </p>
  </section>
</Layout>