---
import Layout from '../components/Layout.astro';

const { title, description } = Astro.props;
---

<Layout title={title} description={description}>
  <section class="max-w-7xl mx-auto px-4 py-16 grid lg:grid-cols-3 gap-10">

    <!-- MAIN CONTENT -->
    <div class="lg:col-span-2">

      <article class="
  prose prose-invert prose-xl
  leading-relaxed max-w-none

  prose-p:mb-6
  prose-li:mb-3

  prose-h2:mt-12 prose-h2:mb-5
  prose-h3:mt-10 prose-h3:mb-4

  prose-strong:text-white
  prose-a:text-emerald-400 hover:prose-a:text-emerald-300
">
        <slot />
      </article>

    </div>

    <!-- SIDEBAR -->
    <aside class="space-y-6">
      <slot name="sidebar" />
    </aside>

  </section>
</Layout>